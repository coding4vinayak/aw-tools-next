{
  "framework": "nextjs",
  "regions": ["iad1"],
  "rewrites": [
    {
      "source": "/",
      "destination": "/index.html"
    },
    {
      "source": "/tools",
      "destination": "/tools/index.html"
    },
    {
      "source": "/tools/:path*",
      "destination": "/tools/:path*"
    },
    {
      "source": "/shared/:path*",
      "destination": "/shared/:path*"
    }
  ]
}
